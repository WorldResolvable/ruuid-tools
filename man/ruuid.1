.I STATE_DIR
.RB [ --out
.IR DIR ]
.RB [ --production ]
.RB [ --challenge
.IR WHAT ]
.RB [ --webroot
.IR DIR ]
.RB [ --commit-host
.IR HOST ]
.RB [ --acme
.IR PATH ]
.br
.B ruuid custody
