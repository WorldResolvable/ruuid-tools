.TH RUUID 1 "July 2026" "ruuid-tools" "User Commands"
.SH NAME
ruuid \- generate and resolve Resolvable UUIDs (RUUIDs)
.SH SYNOPSIS
.B ruuid generate
.I ADDRESS
.RI [ IDENTIFIER ]
.RB [ --type
.IR N ]
.RB [ --day
.IR DATE ]
.RB [ --opaque ]
.br
.B ruuid resolve
.I UUID
.RB [ --registry
.IR URL ]
.RB [ --follow [= WHAT ]]
.RB [ --verbose ]
.RB [ --verify ]
.br
.B ruuid parse
.I UUID
.RB [ --registry
.IR URL ]
.br
.B ruuid document
.B --zone
.I FILE
.RB [ --domain
.IR DOMAIN ]
.br
.B ruuid records
.B --zone
.I FILE
.RB [ --domain
.IR DOMAIN ]
.RB [ --rrtype
